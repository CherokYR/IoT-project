#include <Servo.h>
#include <WiFiS3.h>
#include <WiFiUdp.h>
#include <NTPClient.h>
#include "Ultrasonic.h"

const int hoursToFid = 16;
const int minutesToFid = 0;

Servo myservo;

char ssid[] = "IoTtest";     //name of wifi
char pass[] = "IoTtestTeamA";    //password

WiFiUDP ntpUDP;

NTPClient timeClient(ntpUDP, "pool.ntp.org", 0, 60000); //for using PC time

int pos = 0; //put servo in position 0 

Ultrasonic ultrasonic(7); //connect sonar to D7 

const int buttonPin = 6;

#include "rgb_lcd.h"

rgb_lcd lcd;

const int colorR = 255;
const int colorG = 0;
const int colorB = 0;

void setup() {

  // set up the LCD's number of columns and rows:
  lcd.begin(16, 2);

  lcd.setRGB(colorR, colorG, colorB);

  Serial.begin(9600);

  myservo.attach(5); //connect servo motor to D5
  myservo.write(0);

  Serial.println("Connecting to WiFi...");
  lcd.print("Connecting...");
  delay(1000);
  lcd.clear();

  WiFi.begin(ssid, pass);

  while (WiFi.status() != WL_CONNECTED) { //printinc Connecting if it can`t connect to wifi
    delay(1000);
    Serial.println("Connecting...");
  }

  Serial.println("WiFi connected");
  lcd.print("Connected!");
  delay(1000);
  lcd.clear();

  pinMode(buttonPin, INPUT_PULLUP);

  timeClient.begin();
}

void loop() {

  lcd.print("Time to feed: ");
  lcd.setCursor(0, 1);
  lcd.print(hoursToFid);
  lcd.print(":");
  lcd.print(minutesToFid);
  //writing distance 
  long RangeInInches;
  long RangeInCentimeters;
  RangeInCentimeters = ultrasonic.MeasureInCentimeters(); // two measurements should keep an interval
  Serial.print(RangeInCentimeters);//0~400cm
  Serial.println(" cm");
  delay(250);

  timeClient.update();

  int hourNow = timeClient.getHours(); //taking hours and minutes from PC
  int minuteNow = timeClient.getMinutes();

  Serial.print("Time: ");
  Serial.print(hourNow);
  Serial.print(":");

  if(minuteNow < 10) Serial.print("0");
  Serial.println(minuteNow);


  if(hourNow == hoursToFid && minuteNow == minutesToFid) //feed cat at 17.16, you can change time here 
  {
    lcd.clear();
    lcd.print("Feedding");

    for (pos = 0; pos <= 180; pos++)
    {
      myservo.write(pos);
      delay(15);
    }

    for (pos = 180; pos >= 0; pos--)
    {
      myservo.write(pos);
      delay(15);
    }
    delay(60000);
  }

  if(RangeInCentimeters < 50) //feed when distance less than 50sm
  {
    lcd.clear();
    lcd.setCursor(0, 1);
    lcd.print("Cat is nearby");

    for (pos = 0; pos <= 180; pos++)
    {
      myservo.write(pos);
      delay(15);
    }

    for (pos = 180; pos >= 0; pos--)
    {
      myservo.write(pos);
      delay(15);
    }
  }
  if(digitalRead(buttonPin) == HIGH) 
  {
    lcd.clear();
    lcd.setCursor(1, 0);
    lcd.print("Feedding");
    for (pos = 0; pos <= 180; pos++)
    {
      myservo.write(pos);
      delay(15);
    }

    for (pos = 180; pos >= 0; pos--)
    {
      myservo.write(pos);
      delay(15);
    }
  }

  lcd.clear();


}
